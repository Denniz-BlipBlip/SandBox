    cat > src/database/db.js << DB
const mysql = require('mysql2/promise');

async function getConn() {
  return mysql.createConnection({
    host: process.env.DB_HOST || 'localhost',
    port: process.env.DB_PORT || 3306,
    database: process.env.DB_NAME || 'mydb',
    user: process.env.DB_USER || 'root',
    password: process.env.DB_PASSWORD || ''
  });
}

async function initDB() {
  const conn = await getConn();
  await conn.execute(\`CREATE TABLE IF NOT EXISTS users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(255) NOT NULL
  )\`);
  await conn.end();
}

module.exports = { getConn, initDB };
DB

    cat > src/App.js << JSF
require('dotenv').config();
const { initDB, getConn } = require('./database/db');

(async () => {
  await initDB();
  const conn = await getConn();
  await conn.execute('INSERT INTO users (name) VALUES (?)', ['Hello from $NAME!']);
  const [rows] = await conn.execute('SELECT * FROM users');
  console.log(rows);
  await conn.end();
})();
JSF
    sed -i 's/"dependencies": { "mysql2": "\^3.9.0" }/"dependencies": { "mysql2": "^3.9.0", "dotenv": "^16.4.0" }/' package.json

