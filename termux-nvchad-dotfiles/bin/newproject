    cat > src/App.cs << CS
using System;
using Mono.Data.Sqlite;

class App {
    static void Main() {
        using (var conn = new SqliteConnection("URI=file:mydb.db")) {
            conn.Open();
            var cmd = conn.CreateCommand();
            cmd.CommandText = "CREATE TABLE IF NOT EXISTS users (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT NOT NULL)";
            cmd.ExecuteNonQuery();

            cmd.CommandText = "INSERT INTO users (name) VALUES ('Hello from $NAME!')";
            cmd.ExecuteNonQuery();

            cmd.CommandText = "SELECT id, name FROM users";
            using (var reader = cmd.ExecuteReader()) {
                while (reader.Read()) {
                    Console.WriteLine(reader.GetInt32(0) + " " + reader.GetString(1));
                }
            }
        }
    }
}
CS
    echo "C# + SQLite (Mono.Data.Sqlite) project created at $(pwd)"
    echo "NOTE: Mono.Data.Sqlite.dll ships with the 'mono' Termux package but its exact path"
    echo "      can vary by build. If mcs can't find it, locate it with:"
    echo "        find \$PREFIX -iname 'Mono.Data.Sqlite.dll' 2>/dev/null"
    echo "      and reference it explicitly: mcs -r:/path/to/Mono.Data.Sqlite.dll src/*.cs"

  elif [ "$SUBTYPE" = "mysql" ]; then
